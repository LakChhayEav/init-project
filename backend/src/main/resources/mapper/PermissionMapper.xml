<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.taskapp.mapper.PermissionMapper">
    <select id="findAll" resultType="com.example.taskapp.model.Permission">
        SELECT * FROM permissions
    </select>
    <select id="findById" resultType="com.example.taskapp.model.Permission">
        SELECT * FROM permissions WHERE id = #{id}
    </select>
    <select id="findByRoleId" resultType="com.example.taskapp.model.Permission">
        SELECT p.* FROM permissions p
        JOIN role_permissions rp ON p.id = rp.permission_id
        WHERE rp.role_id = #{roleId}
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO permissions (name, description) VALUES (#{name}, #{description})
    </insert>
    <update id="update">
        UPDATE permissions SET name = #{name}, description = #{description} WHERE id = #{id}
    </update>
    <delete id="delete">
        DELETE FROM permissions WHERE id = #{id}
    </delete>
</mapper>

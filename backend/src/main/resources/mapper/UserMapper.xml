<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.taskapp.mapper.UserMapper">
    <resultMap id="UserMap" type="com.example.taskapp.model.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="email" column="email"/>
        <result property="password" column="password"/>
        <result property="enabled" column="enabled"/>
        <result property="createdAt" column="created_at"/>
        <collection property="roles" column="id" select="com.example.taskapp.mapper.RoleMapper.findByUserId"/>
    </resultMap>

    <select id="findAll" resultMap="UserMap">
        SELECT * FROM users
        <where>
            <if test="search != null and search != ''">
                AND (username LIKE CONCAT('%', #{search}, '%') OR email LIKE CONCAT('%', #{search}, '%'))
            </if>
        </where>
        <if test="limit != null and offset != null">
            LIMIT #{limit} OFFSET #{offset}
        </if>
    </select>
    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM users
        <where>
            <if test="search != null and search != ''">
                AND (username LIKE CONCAT('%', #{search}, '%') OR email LIKE CONCAT('%', #{search}, '%'))
            </if>
        </where>
    </select>
    <select id="findById" resultMap="UserMap">
        SELECT * FROM users WHERE id = #{id}
    </select>
    <select id="findByUsername" resultMap="UserMap">
        SELECT * FROM users WHERE username = #{username}
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (username, email, password, enabled, created_at)
        VALUES (#{username}, #{email}, #{password}, #{enabled}, CURRENT_TIMESTAMP)
    </insert>
    <update id="update">
        UPDATE users SET username = #{username}, email = #{email}, enabled = #{enabled} WHERE id = #{id}
    </update>
    <delete id="delete">
        DELETE FROM users WHERE id = #{id}
    </delete>
    <insert id="addRoleToUser">
        INSERT INTO user_roles (user_id, role_id) VALUES (#{userId}, #{roleId})
    </insert>
    <delete id="removeRoleFromUser">
        DELETE FROM user_roles WHERE user_id = #{userId} AND role_id = #{roleId}
    </delete>
    <delete id="removeAllRolesFromUser">
        DELETE FROM user_roles WHERE user_id = #{userId}
    </delete>
</mapper>
